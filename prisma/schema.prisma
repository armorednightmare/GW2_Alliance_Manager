generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====== SYSTEM ======
model SystemSettings {
  id              String @id @default(cuid())
  allianceName    String @default("Alliance")
  logoUrl         String?
  colorPrimary    String @default("#2c3e50")
  colorAccent     String @default("#27ae60")
  colorBg         String @default("#121212")
  apiSyncInterval Int    @default(60) // in minutes
}

// ====== ROLES ======
model ManualRole {
  id      String @id @default(cuid())
  name    String @unique
  color   String @default("#ffffff")
}

// ====== USERS ======
enum Role {
  ADMIN
  ALLIANCE_LEADER
  GUILD_LEADER
  WEB_MEMBER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?   // For local login
  role          Role      @default(WEB_MEMBER)
  
  // Link to GW2 Member
  memberId      String?   @unique
  member        Member?   @relation(fields: [memberId], references: [id], onDelete: SetNull)

  // External IDs
  discordId     String?

  managedGuilds Guild[] @relation("GuildManagers")

  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ====== GW2 ALLIANCE ======
model Guild {
  id              String   @id @default(uuid()) // GW2 ID or UUID for manual ones
  name            String
  tag             String
  leaderToken     String?  // Optional API key to fetch roster
  isAllianceGuild Boolean  @default(false)
  isManual        Boolean  @default(false) // Flag for non-API guilds

  // Junction table for members
  members          MemberGuild[]
  managers         User[]   @relation("GuildManagers")
}

enum MemberStatus {
  ACTIVE
  INACTIVE_LEFT
  FRIEND
}

model Member {
  id          String   @id @default(cuid())
  accountName String   @unique // e.g. Name.1234
  
  // Refactored to many-to-many via junction table
  guilds      MemberGuild[]
  
  status      MemberStatus @default(ACTIVE)
  wvwMember         Boolean  @default(false)
  isAllianceMember  Boolean  @default(false)
  invitedBy         String?

  // System relation
  linkedUser  User?
  
  // Custom tracking
  manualRole  String?
  comment     String?
  customDiscordName String?

  history     MemberHistory[]

  joinedAt    DateTime?
  lastSeenAt      DateTime? // Automated (Roster Sync)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MemberGuild {
  id          String   @id @default(cuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  guildId     String
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  
  rank        String   // Rank within THIS specific guild
  
  joinedAt    DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@unique([memberId, guildId])
}

// ====== HISTORY ======
enum HistoryEventType {
  JOINED
  LEFT
  RANK_CHANGE
  WVW_STATUS_CHANGE
  COMMENT_ADDED
  COMMENT_CHANGED
  DISCORD_NAME_CHANGED
  MANUAL_ROLE_CHANGED
}

model MemberHistory {
  id          String   @id @default(cuid())
  
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  
  eventType   HistoryEventType
  oldValue    String?
  newValue    String?
  
  createdAt   DateTime @default(now())
}
