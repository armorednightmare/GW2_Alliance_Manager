# Base image for development
FROM node:20-alpine

# Set working directory
WORKDIR /app

# Install dependencies needed for Prisma
RUN apk add --no-cache openssl postgresql-client

# Package.json will be copied/mounted via volume in compose
# But we can copy it initially just in case
COPY package*.json ./

# Expose port
EXPOSE 3000

# Command to run in development (Next.js hot reloading)
CMD ["sh", "-c", "npm install && npx prisma generate && npm run dev"]
