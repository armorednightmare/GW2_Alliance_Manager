# --- Datenbank (Erforderlich) ---
DATABASE_URL="postgresql://postgres:postgres@db:5432/gw2alliance?schema=public"

# --- NextAuth Konfiguration (Erforderlich) ---
# Generiere einen sicheren String mit 'openssl rand -base64 32'
NEXTAUTH_SECRET="your-super-secret-key-change-it-later"
# URL deiner Instanz (Lokal: http://localhost:3000 | Produktion: https://allianz.deinedomain.com)
NEXTAUTH_URL="http://localhost:3000"

# --- Discord Bot / Sync (Optional) ---
# Wird nur benötigt, wenn Discord-Rollen synchronisiert werden sollen
DISCORD_GUILD_ID=""
DISCORD_BOT_TOKEN=""

# --- Discord OAuth Login (Optional) ---
# Registrierung: https://discord.com/developers/applications
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# --- Google OAuth Login (Optional) ---
# Registrierung: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# HINWEIS: Wenn Discord/Google Login nicht konfiguriert sind, 
# steht nur der Login via E-Mail/Passwort (lokale Accounts) zur Verfügung.
